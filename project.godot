; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Drone Tycoon: Sky Fleet"
config/version="1.42.0"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/show_image=false
config/icon="res://appicon.png"

[autoload]

GodotPlayGameServices="*uid://ly1fx0ba2v1m"
Fmt="*res://scripts/format.gd"
Economy="*res://scripts/economy.gd"
Billing="*res://scripts/billing.gd"
Ads="*res://scripts/ads.gd"
AntiCheat="*res://scripts/anti_cheat.gd"
Fx="*res://scripts/fx.gd"
Events="*res://scripts/events.gd"
Prestige="*res://scripts/prestige.gd"
Achievements="*res://scripts/achievements.gd"
Daily="*res://scripts/daily.gd"
GameState="*res://scripts/game_state.gd"
Audio="*res://scripts/audio.gd"
SaveSystem="*res://scripts/save_system.gd"
Contracts="*res://scripts/contracts.gd"
CloudSave="*res://scripts/cloud_save.gd"
Notifications="*res://scripts/notifications.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[editor_plugins]

enabled=PackedStringArray("res://addons/AdmobPlugin/plugin.cfg", "res://addons/GodotGooglePlayBilling/plugin.cfg", "res://addons/NotificationSchedulerPlugin/plugin.cfg")

[internationalization]

locale/translations=PackedStringArray("res://translations/ui.pt.translation", "res://translations/ui.en.translation", "res://translations/ui.es.translation", "res://translations/ui.fr.translation", "res://translations/ui.de.translation", "res://translations/ui.it.translation", "res://translations/ui.ru.translation", "res://translations/ui.ja.translation", "res://translations/ui.zh.translation")

[physics]

"#thegamehaszeroRigidBody2D/CharacterBody2D/Area2D/StaticBody2Dnodesand#neveruses_physics_processâthedefault60physicsticks/secwerestill#steppingandthread-syncingthe(unused)physicsservereveryframeon#Androidfornothing.1istheminimumacceptedvalue(0isinvalid).common/physics_ticks_per_second"=1

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
